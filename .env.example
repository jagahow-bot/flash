# =============================================================================
# FLASH — Environment variables
# Copy to .env.local for local dev.
# On Render: set the same keys in Dashboard → Environment (see docs/DEPLOY.md).
# =============================================================================

# --- Firebase (client) — NEXT_PUBLIC_* are embedded at build time ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin SDK (server only) ---
# Private key: paste the full key; use literal \n for newlines in Render dashboard
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Firestore seed (local only — npm run seed) ---
SEED_ADMIN_UID=
SEED_ARTIST_UID=

# --- Google Gemini (AI brief generation) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Public app URL ---
# Production: https://your-domain.com (no trailing slash)
# Render sets RENDER_EXTERNAL_URL automatically; set this when using a custom domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Transactional email (Resend — https://resend.com) ---
RESEND_API_KEY=
EMAIL_FROM=FLASH <hello@ink-flash.com>
